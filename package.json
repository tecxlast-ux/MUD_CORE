{
  "name": "punnaraj-mud-control-plane",
  "version": "0.1.0",
  "private": true,
  "description": "PUNNARAJ Control Plane v0.1 for the punnaraj/mud Cloudflare Pages repository.",
  "scripts": {
    "build": "npm run validate && npm run build:reference && npm run validate",
    "build:reference": "python3 scripts/build_reference_layers.py",
    "build:atlas": "python3 scripts/build_reference_layers.py --layer public",
    "build:beta": "python3 scripts/build_reference_layers.py --layer beta",
    "validate:public": "python3 scripts/build_reference_layers.py --validate-only",
    "dev": "npx wrangler pages dev . --port 8788",
    "validate": "python3 scripts/validators/check_repo_structure.py"
  }
}
